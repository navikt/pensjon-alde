{
  "name": "alde",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "NODE_ENV=development node --experimental-strip-types server.ts",
    "dev:mock": "NODE_ENV=mock react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "biome ci .",
    "test": "vitest",
    "test:ci": "export CI=true && vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "storybook": "STORYBOOK=true storybook dev -p 6006",
    "build-storybook": "STORYBOOK=true storybook build",
    "capture-screenshots": "pnpm tsx scripts/capture-screenshots.ts",
    "capture-docs-screenshots": "pnpm tsx scripts/capture-screenshots.ts --docs",
    "typecheck": "react-router typegen && tsc",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.8.1",
    "@grafana/faro-web-tracing": "^2.8.1",
    "@navikt/aksel-icons": "^8.14.0",
    "@navikt/ds-css": "^8.14.0",
    "@navikt/ds-react": "^8.14.0",
    "@navikt/ds-tokens": "^8.14.0",
    "@react-router/express": "^8.1.0",
    "@react-router/node": "^8.1.0",
    "@react-router/serve": "^8.1.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "isbot": "^5.1.44",
    "node-cache": "^5.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "remix-auth": "^4.2.0",
    "remix-auth-oauth2": "^3.4.1",
    "unleash-client": "^6.11.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "^8.1.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "glob": "^13.0.6",
    "lefthook": "^2.1.9",
    "msw": "^2.14.6",
    "playwright": "1.61.1",
    "react-router-devtools": "^6.2.1",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
